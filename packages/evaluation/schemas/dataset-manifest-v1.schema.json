{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflo.invalid/schemas/dataset-manifest-v1.schema.json",
  "title": "Reflo dataset-manifest-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "contractVersion",
    "datasetId",
    "datasetVersion",
    "heldOut",
    "intendedGates",
    "items",
    "manifestSchemaVersion",
    "preRunExclusions",
    "protocols",
    "rightsApprovalReferences",
    "selection"
  ],
  "properties": {
    "authority": { "enum": ["authoritative", "fixture"] },
    "contractVersion": { "const": "evaluation-contract-v1" },
    "datasetId": { "$ref": "#/$defs/opaqueId" },
    "datasetVersion": { "$ref": "#/$defs/opaqueId" },
    "heldOut": { "const": true },
    "intendedGates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/gateId" }
    },
    "items": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/document" },
          { "$ref": "#/$defs/audioScript" },
          { "$ref": "#/$defs/uploadSecurity" },
          { "$ref": "#/$defs/adversarialDocument" }
        ]
      }
    },
    "manifestSchemaVersion": { "const": "dataset-manifest-v1" },
    "preRunExclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["itemId", "reason"],
        "properties": {
          "itemId": { "$ref": "#/$defs/opaqueId" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "protocols": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adjudication", "annotation", "reviewer", "rubric"],
      "properties": {
        "adjudication": { "$ref": "#/$defs/protocolVersion" },
        "annotation": { "$ref": "#/$defs/protocolVersion" },
        "reviewer": { "$ref": "#/$defs/protocolVersion" },
        "rubric": { "$ref": "#/$defs/protocolVersion" }
      }
    },
    "rightsApprovalReferences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/safeReference" }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "seed"],
      "properties": {
        "method": { "type": "string", "minLength": 1, "maxLength": 240 },
        "seed": { "type": ["integer", "null"] }
      }
    }
  },
  "$defs": {
    "gateId": {
      "enum": [
        "week1.performance",
        "week1.audio",
        "week1.upload-security",
        "week1.adversarial"
      ]
    },
    "opaqueId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._/-]{2,127}$"
    },
    "protocolVersion": { "type": "string", "minLength": 1, "maxLength": 240 },
    "safeReference": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9+.-]*:[^\\s@]{3,300}$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "strata": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9:._/-]{2,80}$"
      }
    },
    "baseProperties": {
      "id": { "$ref": "#/$defs/opaqueId" },
      "rightsApprovalReference": { "$ref": "#/$defs/safeReference" },
      "sha256": { "$ref": "#/$defs/sha256" },
      "strata": { "$ref": "#/$defs/strata" }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "byteLength",
        "complexity",
        "format",
        "hasImages",
        "hasTables",
        "id",
        "kind",
        "pageCount",
        "rightsApprovalReference",
        "sha256",
        "standardProfileEligibilityReference",
        "strata"
      ],
      "properties": {
        "byteLength": {
          "type": "integer",
          "minimum": 524288,
          "maximum": 20971520
        },
        "complexity": { "enum": ["complex", "simple"] },
        "format": { "enum": ["docx", "epub", "pdf"] },
        "hasImages": { "type": "boolean" },
        "hasTables": { "type": "boolean" },
        "id": { "$ref": "#/$defs/opaqueId" },
        "kind": { "const": "document" },
        "pageCount": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 5, "maximum": 200 }
          ]
        },
        "rightsApprovalReference": { "$ref": "#/$defs/safeReference" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "standardProfileEligibilityReference": {
          "$ref": "#/$defs/safeReference"
        },
        "strata": { "$ref": "#/$defs/strata" }
      }
    },
    "audioScript": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "courseId",
        "id",
        "kind",
        "rightsApprovalReference",
        "scriptByteLength",
        "sha256",
        "strata"
      ],
      "properties": {
        "courseId": { "$ref": "#/$defs/opaqueId" },
        "id": { "$ref": "#/$defs/opaqueId" },
        "kind": { "const": "audio-script" },
        "rightsApprovalReference": { "$ref": "#/$defs/safeReference" },
        "scriptByteLength": { "type": "integer", "minimum": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "strata": { "$ref": "#/$defs/strata" }
      }
    },
    "uploadSecurity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedOutcome",
        "id",
        "kind",
        "rightsApprovalReference",
        "sha256",
        "strata"
      ],
      "properties": {
        "expectedOutcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "id": { "$ref": "#/$defs/opaqueId" },
        "kind": { "const": "upload-security" },
        "rightsApprovalReference": { "$ref": "#/$defs/safeReference" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "strata": { "$ref": "#/$defs/strata" }
      }
    },
    "adversarialDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "rightsApprovalReference",
        "sha256",
        "strata",
        "threatClasses"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/opaqueId" },
        "kind": { "const": "adversarial-document" },
        "rightsApprovalReference": { "$ref": "#/$defs/safeReference" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "strata": { "$ref": "#/$defs/strata" },
        "threatClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "cross-scope-reference",
              "fake-citation",
              "grading-manipulation",
              "indirect-prompt-injection",
              "tool-use-request"
            ]
          }
        }
      }
    }
  }
}
