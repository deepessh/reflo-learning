{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env.example",
    ".prettierignore",
    "eslint.config.mjs",
    "packages/tsconfig/*.json"
  ],
  "globalEnv": ["NEXT_PUBLIC_REFLO_ENV", "REFLO_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["REFLO_SKIP_SCHEMA_DUMP", "TEST_DATABASE_URL"],
      "outputs": []
    }
  }
}
