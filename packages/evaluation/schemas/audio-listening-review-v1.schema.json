{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflo.invalid/schemas/audio-listening-review-v1.schema.json",
  "title": "Reflo audio-listening-review-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intelligibleAt1_5x",
    "intelligibleAt1x",
    "reviewSchemaVersion",
    "reviewerId"
  ],
  "properties": {
    "intelligibleAt1_5x": { "type": "boolean" },
    "intelligibleAt1x": { "type": "boolean" },
    "reviewSchemaVersion": { "const": "audio-listening-review-v1" },
    "reviewerId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{8,128}$"
    }
  }
}
