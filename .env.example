REFLO_ENV=dev
API_HOST=127.0.0.1
API_PORT=3001
NEXT_PUBLIC_REFLO_ENV=dev
NEXT_PUBLIC_REFLO_API_ORIGIN=http://127.0.0.1:3001

# scripts/local-stack.sh generates ignored database credentials and application
# URLs under .reflo/local-stack. These loopback ports may be overridden before
# the first start; remove that generated directory to regenerate configuration.
REFLO_LOCAL_RDS_PORT=55432
REFLO_LOCAL_VECTOR_PORT=55433

# Development smoke adapters only. This literal API key is a non-secret local
# placeholder; replace it through an ignored environment file if your local
# LiteLLM proxy requires a key. These settings are rejected outside REFLO_ENV=dev.
REFLO_LITELLM_BASE_URL=http://127.0.0.1:4000
REFLO_LITELLM_API_KEY=dev-only-placeholder
REFLO_LITELLM_TEXT_MODEL=reflo-local-text
REFLO_LITELLM_EMBEDDING_MODEL=reflo-local-embedding

# Auth is disabled by default in dev. Staging and pilot require "directmail".
REFLO_AUTH_EMAIL_ADAPTER=disabled
DATABASE_URL=
REFLO_AUTH_CALLBACK_ORIGINS=
REFLO_AUTH_EMAIL_ENCRYPTION_KEY=
REFLO_AUTH_LOOKUP_KEY=
REFLO_AUTH_SESSION_DIGEST_KEY=
REFLO_AUTH_TOKEN_DIGEST_KEY=

# DirectMail production eligibility and sender configuration.
REFLO_DIRECTMAIL_ELIGIBILITY=
REFLO_DIRECTMAIL_REGION=
REFLO_DIRECTMAIL_RAM_ROLE_NAME=
REFLO_DIRECTMAIL_SENDER_ADDRESS=
REFLO_DIRECTMAIL_FROM_ALIAS=
REFLO_DIRECTMAIL_DAILY_LIMIT=200
REFLO_DIRECTMAIL_TOTAL_LIMIT=2000
