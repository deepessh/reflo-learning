{
  "name": "@reflo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "schema.sql",
    "scripts"
  ],
  "scripts": {
    "build": "node scripts/check-migrations.mjs && tsc -p tsconfig.build.json",
    "db:dump": "scripts/dump-schema-from-container.sh",
    "db:migrate": "node scripts/strict-migrate.mjs",
    "lint": "eslint scripts src test",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@reflo/accounts": "workspace:*",
    "dbmate": "2.34.1",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "5.9.3"
  }
}
